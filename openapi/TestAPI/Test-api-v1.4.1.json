{
  "openapi": "3.0.1",
  "info": {
    "title": "TestAPI",
    "description": "Minimal anonymisierte API-Beschreibung",
    "version": "1.4.1"
  },
  "paths": {
    "/resources/{resourceId}/operations/{operationType}": {
      "get": {
        "summary": "Get resource operation data",
        "description": "Minimaler GET-Endpunkt zur Abfrage von Informationen zu einer Ressource.",
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "operationType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Erfolgreiche Abfrage",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client-Fehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server-Fehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/resources/{resourceId}/items/{itemId}": {
      "put": {
        "summary": "Update item",
        "description": "Minimaler PUT-Endpunkt zur Aktualisierung eines Items.",
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Erfolgreiche Aktualisierung",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client-Fehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server-Fehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Generische Fehlerantwort.",
        "properties": {
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "An error occurred"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "requestId": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          }
        }
      },
      "GenericResponse": {
        "type": "object",
        "description": "Generische Erfolgsantwort.",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "message": {
            "type": "string",
            "example": "Operation completed successfully"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "requestId": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "payload": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "UpdateRequest": {
        "type": "object",
        "description": "Minimaler Request-Body für eine Aktualisierung.",
        "properties": {
          "data": {
            "type": "object",
            "description": "Beliebige fachliche Daten."
          }
        },
        "required": [
          "data"
        ]
      }
    }
  }
}
